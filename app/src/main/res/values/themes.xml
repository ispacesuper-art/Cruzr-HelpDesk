<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="Theme.HelpDeskApp" parent="Theme.MaterialComponents.Light.NoActionBar">
        <item name="colorPrimary">@color/unisc_blue</item>
        <item name="colorPrimaryVariant">@color/unisc_blue_dark</item>
        <item name="colorOnPrimary">@color/unisc_background</item>
        <item name="colorSecondary">@color/unisc_yellow</item>
        <item name="android:statusBarColor">@color/unisc_blue_dark</item>
        <item name="android:windowBackground">@color/unisc_background</item>
        <item name="android:textColorPrimary">@color/unisc_text</item>
    </style>

    <style name="Widget.HelpDesk.PillButton" parent="Widget.MaterialComponents.Button">
        <item name="android:textAllCaps">false</item>
        <item name="android:textStyle">bold</item>
        <item name="cornerRadius">32dp</item>
        <item name="android:minHeight">64dp</item>
        <item name="android:textSize">20sp</item>
        <item name="android:insetTop">0dp</item>
        <item name="android:insetBottom">0dp</item>
    </style>

    <style name="Widget.HelpDesk.PillButton.Listen" parent="Widget.HelpDesk.PillButton">
        <item name="backgroundTint">@color/unisc_blue</item>
        <item name="android:textColor">@color/unisc_background</item>
    </style>

    <style name="Widget.HelpDesk.PillButton.Stop" parent="Widget.HelpDesk.PillButton">
        <item name="backgroundTint">@color/unisc_stop_blue</item>
        <item name="android:textColor">@color/unisc_background</item>
    </style>

    <style name="Widget.HelpDesk.PillButton.Exit" parent="Widget.MaterialComponents.Button">
        <item name="android:textAllCaps">false</item>
        <item name="android:textStyle">bold</item>
        <item name="cornerRadius">20dp</item>
        <item name="backgroundTint">@color/unisc_blue</item>
        <item name="android:textColor">@color/unisc_background</item>
        <item name="android:minHeight">48dp</item>
        <item name="android:textSize">16sp</item>
    </style>
</resources>
